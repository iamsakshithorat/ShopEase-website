pipeline {
    agent any
    environment {
        SERVER_IP      = '172.31.2.135'
        SSH_CREDENTIAL = 'Shop-pipeline-key'
        REPO_URL       = 'https://github.com/iamsakshithorat/ShopEase-website.git'   // apna actual HTML repo URL daalein
        BRANCH         = 'main'
        REMOTE_USER    = 'ubuntu'
        NGINX_WEB_ROOT = '/var/www/html/shopease'   // nginx ka default web root (Ubuntu pe ye hi hota hai)
    }

    stages {

        stage('Clone Repository') {
            steps {
                git branch: "${BRANCH}", url: "${REPO_URL}"
            }
        }

        // Agar target server pe nginx already installed nahi hai to ye stage uncomment karein
        /*
        stage('Install Nginx on Server') {
            steps {
                sshagent([SSH_CREDENTIAL]) {
                    sh """
                        ssh -o StrictHostKeyChecking=no ${REMOTE_USER}@${SERVER_IP} '
                            sudo apt update &&
                            sudo apt install -y nginx
                        '
                    """
                }
            }
        }
        */

        stage('Upload HTML Files to Nginx Server') {
            steps {
                sshagent([SSH_CREDENTIAL]) {
                    sh """
                        ssh -o StrictHostKeyChecking=no ${REMOTE_USER}@${SERVER_IP} 'sudo mkdir -p ${NGINX_WEB_ROOT} && sudo chown -R ${REMOTE_USER}:${REMOTE_USER} ${NGINX_WEB_ROOT}'
                        scp -o StrictHostKeyChecking=no -r * ${REMOTE_USER}@${SERVER_IP}:${NGINX_WEB_ROOT}/
                    """
                }
            }
        }

        stage('Reload Nginx') {
            steps {
                sshagent([SSH_CREDENTIAL]) {
                    sh """
                        ssh -o StrictHostKeyChecking=no ${REMOTE_USER}@${SERVER_IP} '
                            sudo nginx -t &&
                            sudo systemctl restart nginx
                        '
                    """
                }
            }
        }
    }

    post {
        success {
            echo '✅ Static site deployed successfully via Nginx!'
        }
        failure {
            echo '❌ Deployment failed.'
        }
    }
}